{
  "uid": "ticketing-saga",
  "title": "Ticketing Saga — Overview",
  "tags": ["ticketing", "saga", "kafka"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Services up",
      "description": "How many of the four services Prometheus is currently scraping successfully.",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(up{job=~\".*-service\"})",
          "instant": true
        }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "max": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 4 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Payment breaker OPEN",
      "description": "1 while the paymentGateway circuit breaker is OPEN (fast-failing). Should be 0 in steady state; goes to 1 during a gateway outage and back to 0 as it recovers.",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(resilience4j_circuitbreaker_state{state=\"open\"})",
          "instant": true
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "OPEN", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total consumer lag",
      "description": "Sum of unprocessed messages across every consumer group. The single number that says 'are consumers keeping up?'. Steady non-zero that grows = falling behind.",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kafka_consumergroup_lag_sum)",
          "instant": true
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Saga event throughput (events/sec by topic)",
      "description": "Rate of Kafka records each listener processes, per source topic. This is the saga in motion: orders.placed -> inventory.reserved -> payments.authorized -> orders.confirmed. A healthy flow shows the steps rise together.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (messaging_source_name) (rate(spring_kafka_listener_seconds_count[1m]))",
          "legendFormat": "{{messaging_source_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Consumer lag by group / topic",
      "description": "Per consumer-group, per-topic lag. Broker-side (kafka-exporter), so it still reports when a consumer is dead — which is exactly when lag matters most.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (consumergroup, topic) (kafka_consumergroup_lag_sum) > 0",
          "legendFormat": "{{consumergroup}} / {{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 15, "showPoints": "auto" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Listener errors (events/sec by topic)",
      "description": "Rate of listener invocations that threw. Sustained non-zero here feeds the DLQ — cross-check with `make dlq`. Zero is the expected steady state.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (messaging_source_name) (rate(spring_kafka_listener_seconds_count{error!=\"none\"}[1m]))",
          "legendFormat": "{{messaging_source_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20, "showPoints": "auto", "gradientMode": "opacity" },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "state-timeline",
      "title": "Circuit breaker state",
      "description": "paymentGateway breaker over time. Each state series is 1 when active. The full trip cycle CLOSED -> OPEN -> HALF_OPEN -> CLOSED shows as bands here.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "refId": "A",
          "expr": "resilience4j_circuitbreaker_state{state=~\"closed|open|half_open\"} == 1",
          "legendFormat": "{{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80 },
          "mappings": [ { "type": "value", "options": { "1": { "text": "" } } } ],
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "showValue": "never", "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 8,
      "type": "text",
      "title": "Traces",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 22 },
      "options": {
        "mode": "markdown",
        "content": "Metrics tell you **that** something is slow or failing; **traces tell you where**. Open [Jaeger](http://localhost:16686) and search service `order-service` to follow one order across all four services as a single trace. See `docs/notes/15-observability-tracing.md`."
      }
    }
  ]
}
