# Copy to .env and adjust. Placeholders only — infra not built yet.

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_CONSUMER_GROUP_PREFIX=ticketing
KAFKA_DLQ_SUFFIX=.DLQ

# ---- PostgreSQL (database-per-service) ----
ORDER_DB_URL=jdbc:postgresql://localhost:5432/order_db
ORDER_DB_USER=order
ORDER_DB_PASSWORD=changeme

INVENTORY_DB_URL=jdbc:postgresql://localhost:5433/inventory_db
INVENTORY_DB_USER=inventory
INVENTORY_DB_PASSWORD=changeme

PAYMENT_DB_URL=jdbc:postgresql://localhost:5434/payment_db
PAYMENT_DB_USER=payment
PAYMENT_DB_PASSWORD=changeme

NOTIFICATION_DB_URL=jdbc:postgresql://localhost:5435/notification_db
NOTIFICATION_DB_USER=notification
NOTIFICATION_DB_PASSWORD=changeme

# ---- Redis (cache-aside + distributed lock) ----
REDIS_URL=redis://localhost:6379
REDIS_LOCK_TTL_MS=5000

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=ticketing
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---- Resilience4j (defaults; override per service) ----
RESILIENCE_RETRY_MAX_ATTEMPTS=3
RESILIENCE_RETRY_BACKOFF_MS=500
RESILIENCE_CB_FAILURE_RATE_THRESHOLD=50

# ---- Dashboard (Next.js) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
